APP_NAME=Bowen AI API
APP_VERSION=1.0.0

# -------------------------------
# Firebase
# -------------------------------
# Service Account JSON: Path (e.g., credentials.json) OR the raw JSON string itself
FIREBASE_CREDENTIALS=your_service_account_key.json
FIREBASE_PROJECT_ID=bowen-assistant-XXXXX

# -------------------------------
# JWT / Security
# -------------------------------
# ALWAYS GENERATE A NEW SECRET IN PRODUCTION (e.g., openssl rand -hex 32)
SECRET_KEY=YOUR_SECURE_RANDOM_STRING
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_HOURS=24

# -------------------------------
# Qdrant
# -------------------------------
QDRANT_URL=https://XXX.cloud.qdrant.io
QDRANT_API_KEY=YOUR_API_KEY
QDRANT_COLLECTION_NAME=bowen_documents
EMBEDDING_MODEL=sentence-transformers/all-MiniLM-L6-v2
UPLOAD_DIR=uploads
CHUNK_SIZE=800
CHUNK_OVERLAP=150

# -------------------------------
# Groq
# -------------------------------
GROQ_API_KEY=YOUR_GROQ_API_KEY
GROQ_API_MODEL=llama3-70b-8192

# -------------------------------
# SMTP (for admin OTP)
# -------------------------------
SMTP_HOST=smtp.gmail.com
SMTP_PORT=465
SMTP_USER=your_email@gmail.com
SMTP_PASSWORD=abcd efgh ijkl mnop
SMTP_FROM_NAME=Bowen AI
EMAIL_FROM=Bowen AI <your_email@gmail.com>

ADMIN_REGISTRATION_SECRET=A_SECURE_ADMIN_PASSCODE
